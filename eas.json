{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "development-device": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "SHOW_EXPERIMENTS": "true"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "production-apk": {
      "extends": "production",
      "environment": "production",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production-store": {
      "extends": "production",
      "environment": "production",
      "env": {
        "SHOW_EXPERIMENTS": "false"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "coledriscoll@gmail.com",
        "appleTeamId": "CCL5FAK3ZA",
        "ascAppId": "6760977260"
      },
      "android": {
        "track": "internal"
      }
    }
  }
}
